# Base URL of the FindGreatStocks Express API (server)
SEO_API_BASE=http://localhost:5002
# Or for client-side fetch:
# NEXT_PUBLIC_API_BASE=http://localhost:5002

# Canonical URL of this SEO app (for sitemap and Open Graph)
NEXT_PUBLIC_SITE_URL=https://findgreatstocks.com

# Main scanner app URL (for "Open in Scanner" links)
NEXT_PUBLIC_CLIENT_URL=https://findgreatstocks.com

# Optional: secret for on-demand revalidation
# REVALIDATE_SECRET=your-secret
